# Django
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=

# PostgreSQL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# CORS
CORS_ALLOW_ALL_ORIGINS=

# Facturación (Decimal como string, ej. 0.12 = 12%)
MOTOSHOP_IVA_RATE=0.12

# PostgreSQL tests (opcional, para test_concurrency_postgres)
# Crear BD de prueba como superusuario PostgreSQL:
#   CREATE DATABASE motoshop_test OWNER motoshop_user;
#   ALTER USER motoshop_user CREATEDB;
TEST_DB_NAME=motoshop_test
TEST_DB_USER=
TEST_DB_PASSWORD=
TEST_DB_HOST=
TEST_DB_PORT=

# Datos de desarrollo (seed_dev_data)
# SEED_DEV_PASSWORD=          # obligatoria recomendada; si falta, se genera una aleatoria
# SEED_ADMIN_USERNAME=admin_dev
# SEED_CLIENT_USERNAME=cliente_dev

# IMPORTANTE: variables DB_* exportadas en el shell tienen prioridad sobre este archivo.

