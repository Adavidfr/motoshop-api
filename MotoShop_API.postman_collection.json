{
  "info": {
    "name": "MotoShop API - CRUD Completo",
    "_postman_id": "motoshop-crud-2026",
    "description": "Colección completa para testear las 6 tablas del esquema SQL:\nclientes_perfil, carrito_compras, items_carrito, pedidos, ventas, financiamientos.\n\nFlujo recomendado:\n1. Auth → Register / Login (obtener token)\n2. clientes_perfil → CRUD\n3. carrito_compras → CRUD + acciones custom\n4. items_carrito → CRUD\n5. pedidos → CRUD + confirm + update-status\n6. ventas → CRUD + financiar\n7. financiamientos → CRUD\n\nVariables de colección: base_url, token, admin_token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:8000/api", "type": "string" },
    { "key": "token",        "value": "",  "type": "string", "description": "JWT del cliente (se llena automáticamente en Login)" },
    { "key": "admin_token",  "value": "",  "type": "string", "description": "JWT del admin/vendedor" },
    { "key": "id_perfil",    "value": "1", "type": "string" },
    { "key": "id_carrito",   "value": "1", "type": "string" },
    { "key": "id_item",      "value": "1", "type": "string" },
    { "key": "id_pedido",    "value": "1", "type": "string" },
    { "key": "id_venta",     "value": "1", "type": "string" },
    { "key": "id_financiamiento", "value": "1", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "0 - Auth",
      "item": [
        {
          "name": "Register (cliente)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cliente1\",\n  \"email\": \"cliente1@motoshop.com\",\n  \"password\": \"Test1234!\",\n  \"password2\": \"Test1234!\"\n}"
            }
          }
        },
        {
          "name": "Login (cliente) → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access) pm.collectionVariables.set('token', res.access);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cliente1\",\n  \"password\": \"Test1234!\"\n}"
            }
          }
        },
        {
          "name": "Login (admin) → guarda admin_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access) pm.collectionVariables.set('admin_token', res.access);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/token/refresh/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"<pega aquí el refresh token>\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/logout/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"<pega aquí el refresh token>\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "1 - clientes_perfil",
      "item": [
        {
          "name": "LIST - Listar perfiles (admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{base_url}}/clientes/"
          }
        },
        {
          "name": "READ - Ver mi perfil",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{base_url}}/clientes/perfil/"
          }
        },
        {
          "name": "CREATE - Crear mi perfil",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id_perfil) pm.collectionVariables.set('id_perfil', res.id_perfil);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/clientes/perfil/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cedula\": \"1234567890\",\n  \"telefono\": \"0991234567\",\n  \"direccion\": \"Av. Amazonas N123, Quito\",\n  \"fecha_nacimiento\": \"1995-06-15\"\n}"
            }
          }
        },
        {
          "name": "UPDATE - Actualizar mi perfil (PATCH)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/clientes/perfil/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"0999999999\",\n  \"direccion\": \"Calle Nueva 456, Guayaquil\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Eliminar mi perfil",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{base_url}}/clientes/perfil/"
          }
        }
      ]
    },

    {
      "name": "2 - carrito_compras",
      "item": [
        {
          "name": "LIST - Listar carritos",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/carritos/",
              "query": [
                { "key": "estado", "value": "activo", "disabled": true },
                { "key": "from_date", "value": "2025-01-01", "disabled": true },
                { "key": "to_date",   "value": "2025-12-31", "disabled": true }
              ]
            }
          }
        },
