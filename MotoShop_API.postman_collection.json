    {
      "name": "6 - financiamientos",
      "item": [
        {
          "name": "LIST - Listar financiamientos",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/financiamientos/",
              "query": [
                { "key": "estado",             "value": "activo",           "disabled": true },
                { "key": "id_venta",           "value": "1",                "disabled": true },
                { "key": "entidad_financiera", "value": "Banco Pichincha",  "disabled": true },
                { "key": "monto_min",          "value": "5000",             "disabled": true },
                { "key": "monto_max",          "value": "20000",            "disabled": true }
              ]
            }
          }
        },
        {
          "name": "CREATE - Crear financiamiento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
