          "name": "CREATE - Crear carrito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id_carrito) pm.collectionVariables.set('id_carrito', res.id_carrito);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carritos/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"activo\"\n}"
            }
          }
        },
        {
          "name": "READ - Detalle de carrito",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{base_url}}/carritos/{{id_carrito}}/"
          }
        },
        {
          "name": "UPDATE - Cambiar estado del carrito (PATCH)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carritos/{{id_carrito}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"activo\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Eliminar carrito",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{base_url}}/carritos/{{id_carrito}}/"
          }
        },
        {
          "name": "ACTION - Carrito activo del usuario",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{base_url}}/carritos/activo/"
          }
        },
        {
          "name": "ACTION - Agregar ítem al carrito (moto)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carritos/{{id_carrito}}/add-item/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_moto\": 1,\n  \"cantidad\": 1,\n  \"precio_unitario\": \"15000.00\"\n}"
            }
          }
        },
        {
          "name": "ACTION - Agregar ítem al carrito (repuesto)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carritos/{{id_carrito}}/add-item/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_repuesto\": 5,\n  \"cantidad\": 2,\n  \"precio_unitario\": \"250.00\"\n}"
            }
          }
        },
        {
          "name": "ACTION - Quitar ítem del carrito",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{base_url}}/carritos/{{id_carrito}}/remove-item/{{id_item}}/"
          }
        },
        {
          "name": "ACTION - Vaciar carrito",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "url": "{{base_url}}/carritos/{{id_carrito}}/vaciar/"
          }
        }
      ]
    },

